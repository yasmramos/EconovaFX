<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.ThirdPartyFormController"
      spacing="20"
      styleClass="p-5, bg-white"
      prefWidth="600" prefHeight="550">

    <!-- Header -->
    <Label fx:id="titleLabel" text="New Third Party" styleClass="text-2xl, font-bold, text-gray-800"/>

    <!-- Form -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="rounded-md">
        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="35"/>
                <ColumnConstraints percentWidth="65"/>
            </columnConstraints>

            <!-- Basic Information -->
            <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="ID Number:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="identificationField" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Type:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <ComboBox fx:id="typeComboBox" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="emailField" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Phone:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="phoneField" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Address:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="addressField" GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="City:" GridPane.rowIndex="6" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="cityField" GridPane.rowIndex="6" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Country:" GridPane.rowIndex="7" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="countryField" GridPane.rowIndex="7" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Tax ID (RUC):" GridPane.rowIndex="8" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="taxIdField" GridPane.rowIndex="8" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <!-- Financial Information -->
            <Label text="Credit Limit:" GridPane.rowIndex="9" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="creditLimitField" GridPane.rowIndex="9" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Payment Days:" GridPane.rowIndex="10" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextField fx:id="paymentDaysField" GridPane.rowIndex="10" GridPane.columnIndex="1" styleClass="rounded-md"/>

            <Label text="Active:" GridPane.rowIndex="11" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <CheckBox fx:id="activeCheckBox" GridPane.rowIndex="11" GridPane.columnIndex="1"/>

            <Label text="Notes:" GridPane.rowIndex="12" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
            <TextArea fx:id="notesArea" GridPane.rowIndex="12" GridPane.columnIndex="1"
                      prefRowCount="4" wrapText="true" styleClass="rounded-md"/>
        </GridPane>
    </ScrollPane>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel" styleClass="bg-gray-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-gray-600"/>
        <Button text="Save" onAction="#save" styleClass="bg-green-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-green-600"/>
    </HBox>
    
</VBox>
