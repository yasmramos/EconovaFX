<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>

<StackPane fx:id="rootPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.econovafx.ui.view.SplashController"
           stylesheets="@../css/splash.css">
    
    <VBox alignment="CENTER" spacing="20" StackPane.alignment="CENTER">
        <padding>
            <Insets top="40" right="60" bottom="40" left="60"/>
        </padding>
        
        <!-- Logo / Icono -->
        <ImageView fx:id="logoImage" fitHeight="120" fitWidth="120" preserveRatio="true">
            <!-- Se puede agregar un logo aquí -->
        </ImageView>
        
        <!-- Título de la aplicación -->
        <Label text="EconoNova FX" styleClass="title-label"/>
        
        <!-- Versión -->
        <Label fx:id="versionLabel" styleClass="version-label"/>
        
        <VBox spacing="15" VBox.vgrow="ALWAYS" alignment="CENTER">
            <!-- Barra de progreso -->
            <ProgressBar fx:id="progressBar" prefWidth="400" progress="0"/>
            
            <!-- Label de estado -->
            <Label fx:id="statusLabel" text="Iniciando..." styleClass="status-label"/>
        </VBox>
        
        <!-- Footer -->
        <HBox alignment="CENTER">
            <Label text="Sistema Contable Profesional" styleClass="footer-label"/>
        </HBox>
    </VBox>
</StackPane>
