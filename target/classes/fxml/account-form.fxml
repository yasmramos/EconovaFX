<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.AccountFormController"
      spacing="20"
      styleClass="p-5, bg-white"
      prefWidth="500" prefHeight="400">

    <!-- Header -->
    <Label fx:id="titleLabel" text="Nueva Cuenta" styleClass="text-2xl, font-bold, text-gray-800"/>

    <!-- Form -->
    <GridPane hgap="15" vgap="15" VBox.vgrow="ALWAYS">
        <columnConstraints>
            <ColumnConstraints percentWidth="35"/>
            <ColumnConstraints percentWidth="65"/>
        </columnConstraints>

        <Label text="Código:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <TextField fx:id="codeField" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="rounded-md"/>

        <Label text="Nombre:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="rounded-md"/>

        <Label text="Tipo:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <ComboBox fx:id="typeComboBox" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="rounded-md"/>

        <Label text="Cuenta Padre:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <ComboBox fx:id="parentAccountComboBox" GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="rounded-md"/>

        <Label text="Saldo Inicial:" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <TextField fx:id="balanceField" GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="rounded-md"/>

        <Label text="Descripción:" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="text-sm, font-medium, text-gray-700"/>
        <TextArea fx:id="descriptionArea" GridPane.rowIndex="5" GridPane.columnIndex="1"
                  prefRowCount="3" wrapText="true" styleClass="rounded-md"/>
    </GridPane>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" onAction="#cancel" styleClass="bg-gray-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-gray-600"/>
        <Button text="Guardar" onAction="#save" styleClass="bg-green-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-green-600"/>
    </HBox>
    
</VBox>
