<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.SVGPath?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.AccountingPeriodsController"
      spacing="15"
      styleClass="p-4, bg-gray-50">

    <!-- Header -->
    <VBox spacing="10" styleClass="bg-white, rounded-lg, p-4, shadow-sm">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Accounting Periods Management" styleClass="text-2xl, font-bold, text-gray-800"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="newPeriodButton" text="New Period" onAction="#newPeriod" 
                    styleClass="bg-green-500, text-white, px-5, py-2, rounded-md, cursor-hand, hover:bg-green-600, font-semibold">
                <graphic>
                    <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z" styleClass="fill-white"/>
                </graphic>
            </Button>
        </HBox>
        
        <!-- Quick Stats -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <VBox styleClass="bg-blue-50, rounded-md, p-3" alignment="CENTER" prefWidth="150">
                <Label fx:id="totalPeriodsLabel" text="0" styleClass="text-2xl, font-bold, text-blue-600"/>
                <Label text="Total Periods" styleClass="text-xs, text-gray-600"/>
            </VBox>
            <VBox styleClass="bg-green-50, rounded-md, p-3" alignment="CENTER" prefWidth="150">
                <Label fx:id="openPeriodsLabel" text="0" styleClass="text-2xl, font-bold, text-green-600"/>
                <Label text="Open Periods" styleClass="text-xs, text-gray-600"/>
            </VBox>
            <VBox styleClass="bg-orange-50, rounded-md, p-3" alignment="CENTER" prefWidth="150">
                <Label fx:id="closedPeriodsLabel" text="0" styleClass="text-2xl, font-bold, text-orange-600"/>
                <Label text="Closed Periods" styleClass="text-xs, text-gray-600"/>
            </VBox>
            <VBox styleClass="bg-red-50, rounded-md, p-3" alignment="CENTER" prefWidth="150">
                <Label fx:id="lockedPeriodsLabel" text="0" styleClass="text-2xl, font-bold, text-red-600"/>
                <Label text="Locked Periods" styleClass="text-xs, text-gray-600"/>
            </VBox>
        </HBox>
    </VBox>
    
    <!-- Periods Table -->
    <VBox VBox.vgrow="ALWAYS" spacing="10" styleClass="bg-white, rounded-lg, p-4, shadow-sm">
        
        <!-- Current Status Info -->
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="bg-yellow-50, border-l-4, border-yellow-400, p-3, rounded-md">
            <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                     styleClass="fill-yellow-600"/>
            <Label fx:id="currentPeriodInfo" text="No open period available. Please create or reopen a period." 
                   styleClass="text-sm, text-yellow-800, font-medium"/>
        </HBox>

        <!-- Periods Table -->
        <TableView fx:id="periodsTable" VBox.vgrow="ALWAYS" 
                   styleClass="rounded-lg, border, border-gray-200, table-view-modern">
            <columns>
                <TableColumn fx:id="colName" text="Period Name" prefWidth="250"/>
                <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="120"/>
                <TableColumn fx:id="colEndDate" text="End Date" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colClosedBy" text="Closed By" prefWidth="150"/>
                <TableColumn fx:id="colClosedDate" text="Closed Date" prefWidth="120"/>
                <TableColumn fx:id="colActions" text="Actions" prefWidth="200" editable="false"/>
            </columns>
        </TableView>

        <!-- Action Buttons -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="closePeriodButton" text="Close Period" onAction="#closePeriod" 
                    styleClass="bg-orange-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-orange-600">
                <graphic>
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" 
                           styleClass="fill-white"/>
                </graphic>
            </Button>
            <Button fx:id="reopenPeriodButton" text="Reopen Period" onAction="#reopenPeriod" 
                    styleClass="bg-blue-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-blue-600">
                <graphic>
                    <SVGPath content="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z" 
                           styleClass="fill-white"/>
                </graphic>
            </Button>
            <Button fx:id="lockPeriodButton" text="Lock Period" onAction="#lockPeriod" 
                    styleClass="bg-red-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-red-600">
                <graphic>
                    <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z" 
                           styleClass="fill-white"/>
                </graphic>
            </Button>
        </HBox>
    </VBox>
    
</VBox>
