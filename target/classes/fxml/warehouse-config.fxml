<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.econovafx.ui.controller.WarehouseConfigController"
      spacing="10" styleClass="content-wrapper">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Header -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="section-header">
        <Label text="⚙️ Configuración de Almacenes" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>
    
    <!-- Toolbar -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar">
        <TextField fx:id="searchField" promptText="🔍 Buscar por código, nombre o ubicación..." 
                   HBox.hgrow="ALWAYS" styleClass="search-field"/>
        <Button fx:id="addBtn" text="➕ Nuevo" onAction="#onAddWarehouse" styleClass="btn-primary"/>
        <Button fx:id="editBtn" text="✏️ Editar" onAction="#onEditWarehouse" disable="true" styleClass="btn-secondary"/>
        <Button fx:id="toggleActiveBtn" text="🔄 Activar/Desactivar" onAction="#onToggleActive" disable="true" styleClass="btn-warning"/>
        <Button fx:id="deleteBtn" text="🗑️ Eliminar" onAction="#onDeleteWarehouse" disable="true" styleClass="btn-danger"/>
    </HBox>
    
    <!-- Table -->
    <TableView fx:id="warehouseTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="codeColumn" text="Código" prefWidth="120"/>
            <TableColumn fx:id="nameColumn" text="Nombre" prefWidth="250"/>
            <TableColumn fx:id="locationColumn" text="Ubicación" prefWidth="200"/>
            <TableColumn fx:id="valuationMethodColumn" text="Método de Valoración" prefWidth="220"/>
            <TableColumn fx:id="managerColumn" text="Responsable" prefWidth="180"/>
            <TableColumn fx:id="activeColumn" text="Estado" prefWidth="100"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
    
    <!-- Footer Info -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="💡 Configure los almacenes y seleccione el método de valoración (PEPS o Promedio Ponderado)" 
               styleClass="info-label"/>
    </HBox>
    
</VBox>
