<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.TransactionsController"
      spacing="20"
      styleClass="p-5">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Transacciones" styleClass="text-2xl, font-bold, text-gray-800"/>
        <Region HBox.hgrow="ALWAYS"/>
        <DatePicker fx:id="fromDatePicker" promptText="Desde" styleClass="rounded-md"/>
        <DatePicker fx:id="toDatePicker" promptText="Hasta" styleClass="rounded-md"/>
        <Button text="Filtrar" onAction="#filterTransactions" styleClass="bg-blue-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-blue-600"/>
        <Button text="Nueva Transacción" onAction="#newTransaction" styleClass="bg-green-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-green-600"/>
    </HBox>
    
    <!-- Transactions Table -->
    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS" styleClass="rounded-lg, border, border-gray-200">
            <columns>
                <TableColumn fx:id="colDate" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colNumber" text="Número" prefWidth="120"/>
                <TableColumn fx:id="colType" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colDescription" text="Descripción" prefWidth="250"/>
                <TableColumn fx:id="colReference" text="Referencia" prefWidth="120"/>
                <TableColumn fx:id="colDebit" text="Total Débito" prefWidth="120"/>
                <TableColumn fx:id="colCredit" text="Total Crédito" prefWidth="120"/>
                <TableColumn fx:id="colStatus" text="Estado" prefWidth="100"/>
            </columns>
        </TableView>

        <!-- Action Buttons -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Ver Detalles" onAction="#viewTransactionDetails" styleClass="bg-blue-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-blue-600"/>
            <Button text="Publicar" onAction="#postTransaction" styleClass="bg-green-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-green-600"/>
            <Button text="Reversar" onAction="#reverseTransaction" styleClass="bg-amber-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-amber-600"/>
            <Button text="Eliminar" onAction="#deleteTransaction" styleClass="bg-red-500, text-white, px-4, py-2, rounded-md, cursor-hand, hover:bg-red-600"/>
        </HBox>
    </VBox>
    
</VBox>
