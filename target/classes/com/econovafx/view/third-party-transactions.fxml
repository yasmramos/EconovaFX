<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.econovafx.controller.ThirdPartyTransactionsController" prefWidth="900.0" prefHeight="600.0" styleClass="background">
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="thirdPartyNameLabel" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" text="Third Party Name" />
                        <Label fx:id="thirdPartyIdLabel" style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="ID: " />
                    </children>
                </VBox>
                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label style="-fx-font-size: 14px; -fx-text-fill: #6b7280;" text="Total Balance:" />
                        <Label fx:id="totalBalanceLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #059669;" text="$0.00" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Statistics Cards -->
        <HBox spacing="15.0" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="10.0" top="15.0" />
            </padding>
            <children>
                <VBox styleClass="card" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" text="Total Debit" />
                        <Label fx:id="totalDebitLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #dc2626;" text="$0.00" />
                    </children>
                </VBox>
                <VBox styleClass="card" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" text="Total Credit" />
                        <Label fx:id="totalCreditLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #059669;" text="$0.00" />
                    </children>
                </VBox>
                <VBox styleClass="card" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label style="-fx-font-size: 12px; -fx-text-fill: #6b7280;" text="Transaction Count" />
                        <Label fx:id="transactionCountLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2563eb;" text="0" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Toolbar -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="toolbar" VBox.vgrow="NEVER">
            <padding>
                <Insets bottom="10.0" top="10.0" />
            </padding>
            <children>
                <Button fx:id="exportExcelButton" onAction="#handleExportExcel" styleClass="button-primary" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold;">
                    <graphic>
                        <Label text="📊 Export Excel" />
                    </graphic>
                </Button>
                <Button fx:id="closeButton" onAction="#handleClose" styleClass="button-secondary" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-background-radius: 6;" text="Close" />
            </children>
        </HBox>

        <!-- Transactions Table -->
        <VBox styleClass="card" style="-fx-background-color: white; -fx-background-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 1);" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
                    <columns>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="100.0" />
                        <TableColumn fx:id="voucherTypeColumn" text="Voucher Type" prefWidth="120.0" />
                        <TableColumn fx:id="voucherNumberColumn" text="Voucher #" prefWidth="100.0" />
                        <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250.0" />
                        <TableColumn fx:id="debitColumn" text="Debit" prefWidth="100.0" />
                        <TableColumn fx:id="creditColumn" text="Credit" prefWidth="100.0" />
                        <TableColumn fx:id="balanceColumn" text="Running Balance" prefWidth="120.0" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
