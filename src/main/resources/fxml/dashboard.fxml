<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="bg-gray-100, p-6" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.econovafx.ui.controller.DashboardController">

    <!-- Header with Refresh -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="dashboard-header">
        <VBox>
            <Label styleClass="dashboard-title" text="Dashboard" />
            <Label styleClass="dashboard-subtitle" text="Resumen financiero y transacciones recientes" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="refreshButton" onAction="#refreshDashboard" styleClass="refresh-btn" text="🔄  Actualizar" />
    </HBox>

    <!-- Summary Cards -->
    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="20" />
            <ColumnConstraints percentWidth="20" />
            <ColumnConstraints percentWidth="20" />
            <ColumnConstraints percentWidth="20" />
            <ColumnConstraints percentWidth="20" />
        </columnConstraints>

        <!-- Total Assets Card -->
        <VBox styleClass="summary-card, card-assets" GridPane.columnIndex="0">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox styleClass="card-icon-bg">
                    <Label styleClass="text-3xl" text="💰" />
                </VBox>
                <VBox>
                    <Label styleClass="card-label" text="Total Activos" />
                    <Label fx:id="totalAssetsLabel" styleClass="card-value, value-positive" text="\$ 0.00" />
                    <Label fx:id="assetsTrendLabel" styleClass="card-trend, trend-positive" text="+0%" />
                </VBox>
            </HBox>
        </VBox>

        <!-- Total Liabilities Card -->
        <VBox styleClass="summary-card, card-liabilities" GridPane.columnIndex="1">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox styleClass="card-icon-bg-red">
                    <Label styleClass="text-3xl" text="📋" />
                </VBox>
                <VBox>
                    <Label styleClass="card-label" text="Total Pasivos" />
                    <Label fx:id="totalLiabilitiesLabel" styleClass="card-value, value-negative" text="\$ 0.00" />
                    <Label fx:id="liabilitiesTrendLabel" styleClass="card-trend, trend-positive" text="-0%" />
                </VBox>
            </HBox>
        </VBox>

        <!-- Total Equity Card -->
        <VBox styleClass="summary-card, card-equity" GridPane.columnIndex="2">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox styleClass="card-icon-bg-blue">
                    <Label styleClass="text-3xl" text="🏦" />
                </VBox>
                <VBox>
                    <Label styleClass="card-label" text="Total Patrimonio" />
                    <Label fx:id="totalEquityLabel" styleClass="card-value, value-info" text="\$ 0.00" />
                    <Label fx:id="equityTrendLabel" styleClass="card-trend, trend-neutral" text="▬ 0%" />
                </VBox>
            </HBox>
        </VBox>

        <!-- Balance Card -->
        <VBox styleClass="summary-card, card-balance" GridPane.columnIndex="3">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox styleClass="card-icon-bg-amber">
                    <Label styleClass="text-3xl" text="⚖️" />
                </VBox>
                <VBox>
                    <Label styleClass="card-label" text="Balance General" />
                    <Label fx:id="balanceLabel" styleClass="card-value, value-warning" text="\$ 0.00" />
                    <Label fx:id="balanceTrendLabel" styleClass="card-trend, trend-positive" text="Estable" />
                </VBox>
            </HBox>
        </VBox>
        
        <!-- Profit Card (New KPI) -->
        <VBox styleClass="summary-card, card-profit" GridPane.columnIndex="4">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox styleClass="card-icon-bg-green">
                    <Label styleClass="text-3xl" text="📈" />
                </VBox>
                <VBox>
                    <Label styleClass="card-label" text="Utilidad del Mes" />
                    <Label fx:id="profitLabel" styleClass="card-value, value-success" text="\$ 0.00" />
                    <Label fx:id="profitTrendLabel" styleClass="card-trend, trend-neutral" text="▬ Equilibrio" />
                </VBox>
            </HBox>
        </VBox>
      <rowConstraints>
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <!-- Charts Section -->
    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="33" />
            <ColumnConstraints percentWidth="33" />
            <ColumnConstraints percentWidth="34" />
        </columnConstraints>

        <!-- Pie Chart: Assets vs Liabilities -->
        <VBox styleClass="chart-card" GridPane.columnIndex="0">
            <Label styleClass="chart-title" text="Distribución Financiera" />
            <Label styleClass="chart-subtitle" text="Activos vs Pasivos vs Patrimonio" />
            <PieChart fx:id="financialPieChart" prefHeight="280" />
        </VBox>

        <!-- Bar Chart: Monthly Activity -->
        <VBox styleClass="chart-card" GridPane.columnIndex="1">
            <Label styleClass="chart-title" text="Actividad Mensual" />
            <Label styleClass="chart-subtitle" text="Ingresos vs Gastos (Últimos 6 meses)" />
            <BarChart fx:id="monthlyBarChart" prefHeight="280">
                <xAxis>
                    <CategoryAxis label="Mes" side="BOTTOM" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Monto" side="LEFT" />
                </yAxis>
            </BarChart>
        </VBox>
        
        <!-- Line Chart: Daily Cash Flow -->
        <VBox styleClass="chart-card" GridPane.columnIndex="2">
            <Label styleClass="chart-title" text="Flujo de Caja Diario" />
            <Label styleClass="chart-subtitle" text="Últimos 30 días" />
            <LineChart fx:id="cashFlowLineChart" prefHeight="280">
                <xAxis>
                    <CategoryAxis label="Día" side="BOTTOM" />
                </xAxis>
                <yAxis>
                    <NumberAxis label="Monto" side="LEFT" />
                </yAxis>
            </LineChart>
        </VBox>
      <rowConstraints>
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <!-- Recent Transactions with Filters -->
    <VBox styleClass="bg-white, rounded-xl, shadow-md, p-5" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="filter-section">
            <Label styleClass="filter-label" text="📅 Período:" />
            <DatePicker fx:id="filterStartDate" promptText="Fecha inicio" styleClass="filter-date-picker" />
            <Label styleClass="filter-label" text="—" />
            <DatePicker fx:id="filterEndDate" promptText="Fecha fin" styleClass="filter-date-picker" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#applyFilters" styleClass="filter-btn" text="🔍 Filtrar" />
            <Button onAction="#clearFilters" styleClass="clear-btn" text="🗑️ Limpiar" />
            <Button onAction="#viewAllTransactions" styleClass="view-all-btn" text="📄 Ver Todas" />
        </HBox>

        <TableView fx:id="recentTransactionsTable" styleClass="transactions-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDate" prefWidth="100" text="Fecha" />
                <TableColumn fx:id="colNumber" prefWidth="80" text="Número" />
                <TableColumn fx:id="colType" prefWidth="100" text="Tipo" />
                <TableColumn fx:id="colDescription" prefWidth="250" text="Descripción" />
                <TableColumn fx:id="colDebit" prefWidth="120" text="Débito" />
                <TableColumn fx:id="colCredit" prefWidth="120" text="Crédito" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Estado" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Quick Actions and Statistics -->
    <GridPane hgap="20" vgap="20">
        <columnConstraints>
            <ColumnConstraints percentWidth="34" />
            <ColumnConstraints percentWidth="33" />
            <ColumnConstraints percentWidth="33" />
        </columnConstraints>

        <!-- Quick Transaction -->
        <VBox styleClass="quick-form-card" GridPane.columnIndex="0">
            <Label styleClass="quick-form-title" text="⚡ Nueva Transacción Rápida" />
            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints percentWidth="30" />
                    <ColumnConstraints percentWidth="70" />
                </columnConstraints>

                <Label styleClass="form-label" text="💼 Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <ComboBox fx:id="quickTransactionType" styleClass="form-combo" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label styleClass="form-label" text="📝 Descripción:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="quickDescription" promptText="Descripción de la transacción" styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label styleClass="form-label" text="💵 Monto:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="quickAmount" promptText="0.00" styleClass="form-input" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label styleClass="form-label" text="🏦 Cuenta:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="quickAccountSelect" promptText="Seleccione cuenta" styleClass="form-combo" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <Button onAction="#createQuickTransaction" styleClass="submit-btn" text="✓ Crear Transacción" GridPane.columnIndex="1" GridPane.halignment="RIGHT" GridPane.rowIndex="4" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>
        </VBox>

        <!-- KPI Metrics -->
        <VBox styleClass="stats-card" GridPane.columnIndex="1">
            <Label styleClass="stats-title" text="📈 Indicadores del Mes" />
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-green">
                        <Label styleClass="text-2xl" text="💵" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Ingresos del Mes" />
                        <Label fx:id="revenueLabel" styleClass="stat-value, value-positive" text="$ 0.00" />
                        <Label fx:id="revenueTrendLabel" styleClass="stat-trend" text="Este mes" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-red">
                        <Label styleClass="text-2xl" text="💸" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Gastos del Mes" />
                        <Label fx:id="expensesLabel" styleClass="stat-value, value-negative" text="$ 0.00" />
                        <Label fx:id="expensesTrendLabel" styleClass="stat-trend" text="Este mes" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-blue">
                        <Label styleClass="text-2xl" text="🧾" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Ticket Promedio" />
                        <Label fx:id="averageTransactionLabel" styleClass="stat-value, value-info" text="$ 0.00" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Statistics -->
        <VBox styleClass="stats-card" GridPane.columnIndex="2">
            <Label styleClass="stats-title" text="📊 Estadísticas" />
            <VBox spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-blue">
                        <Label styleClass="text-2xl" text="📝" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Total Transacciones" />
                        <Label fx:id="totalTransactionsLabel" styleClass="stat-value" text="0" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-green">
                        <Label styleClass="text-2xl" text="✅" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Transacciones Publicadas" />
                        <Label fx:id="postedTransactionsLabel" styleClass="stat-value, value-positive" text="0" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-amber">
                        <Label styleClass="text-2xl" text="⏳" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Transacciones Borrador" />
                        <Label fx:id="unpostedTransactionsLabel" styleClass="stat-value, value-warning" text="0" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="stat-item">
                    <HBox styleClass="stat-icon-purple">
                        <Label styleClass="text-2xl" text="📁" />
                    </HBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="Total Cuentas" />
                        <Label fx:id="totalAccountsLabel" styleClass="stat-value, value-info" text="0" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
      <rowConstraints>
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <!-- Loading Overlay -->
    <StackPane fx:id="loadingOverlay" managed="false" styleClass="loading-overlay" visible="false">
        <VBox alignment="CENTER" spacing="16" styleClass="loading-content">
            <ProgressIndicator fx:id="loadingIndicator" progress="-1" />
            <Label styleClass="loading-label" text="Cargando datos..." />
        </VBox>
    </StackPane>

</VBox>
