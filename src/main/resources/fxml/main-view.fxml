<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.MainViewController"
      spacing="0"
      styleClass="bg-gray-50">

    <!-- Top Area: Sidebar + Content -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- Sidebar Navigation (Full Height) -->
        <ScrollPane fx:id="sidebarScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scroll" HBox.hgrow="NEVER">
            <VBox fx:id="sidebarVBox" styleClass="sidebar-container, bg-slate-800" prefWidth="260" minWidth="260" maxWidth="260">

            <!-- Logo/Brand Section -->
            <VBox styleClass="p-6, pb-2">
                <Label text="🚀 EconoNova FX" styleClass="text-white, text-xl, font-bold"/>
                <Label text="Sistema Contable" styleClass="text-slate-400, text-xs, mt-1"/>
            </VBox>

            <!-- MÓDULOS Section -->
            <Label text="MÓDULOS" styleClass="sidebar-section-title"/>

            <Button fx:id="btnDashboard" text="📊 Dashboard" onAction="#showDashboard" styleClass="btn, btn-ghost, sidebar-btn"/>

            <!-- Contabilidad with submenu -->
            <VBox styleClass="sidebar-menu-group">
                <StackPane styleClass="sidebar-btn-wrapper">
                    <Button fx:id="btnContabilidad" text="📒 Contabilidad" onAction="#toggleContabilidadMenu" styleClass="btn, btn-ghost, sidebar-btn"/>
                    <Label fx:id="contabilidadChevron" text="▼" styleClass="sidebar-chevron-float" StackPane.alignment="CENTER_RIGHT"/>
                </StackPane>
                <VBox fx:id="contabilidadSubmenu" visible="false" managed="false" styleClass="sidebar-submenu">
                    <Button fx:id="btnComprobantes" text="📄 Comprobantes de Operaciones" onAction="#showComprobantes" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                    <Button fx:id="btnClasificador" text="🗂️ Clasificador de Cuentas" onAction="#showClasificador" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                    <Button fx:id="btnTerceros" text="👥 Terceros (Clientes/Proveedores)" onAction="#showTerceros" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                    <Button fx:id="btnPeriodos" text="📅 Periodos Contables" onAction="#showPeriodos" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                    <Button fx:id="btnCierres" text="🔒 Cierres Contables" onAction="#showCierres" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                    <Button fx:id="btnCostos" text="💰 Costos y Procesos" onAction="#showCostos" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                </VBox>
            </VBox>

            <Button fx:id="btnFinanzas" text="💹 Finanzas" onAction="#showFinanzas" styleClass="btn, btn-ghost, sidebar-btn"/>
            <Button fx:id="btnAFT" text="📋 AFT" onAction="#showAFT" styleClass="btn, btn-ghost, sidebar-btn"/>
            <Button fx:id="btnInventarios" text="📦 Inventarios" onAction="#showInventarios" styleClass="btn, btn-ghost, sidebar-btn"/>
            <Button fx:id="btnNominas" text="👥 Nóminas" onAction="#showNominas" styleClass="btn, btn-ghost, sidebar-btn"/>

            <!-- Spacer to push system section to bottom -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- SISTEMA Section -->
            <Separator styleClass="sidebar-separator"/>
            <Label text="SISTEMA" styleClass="sidebar-section-title"/>
            <Button fx:id="btnSettings" text="⚙️ Configuración" onAction="#toggleSettingsMenu" styleClass="btn, btn-ghost, sidebar-btn"/>
            <VBox fx:id="settingsSubmenu" visible="false" managed="false" styleClass="sidebar-submenu">
                <Button fx:id="btnPerfil" text="👤 Mi Perfil" onAction="#showPerfil" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                <Button fx:id="btnAppSettings" text="🔧 Ajustes de la App" onAction="#showAppSettings" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
                <Button fx:id="btnBackup" text="💾 Copia de Seguridad" onAction="#showBackup" styleClass="btn, btn-ghost, sidebar-btn, sidebar-submenu-btn"/>
            </VBox>
            <Button fx:id="btnHelp" text="❓ Ayuda" onAction="#showHelp" styleClass="btn, btn-ghost, sidebar-btn"/>
            <Button fx:id="btnAbout" text="ℹ️ Acerca de" onAction="#showAbout" styleClass="btn, btn-ghost, sidebar-btn"/>

        </VBox>
        </ScrollPane>

        <!-- Right Side: Header + Content -->
        <BorderPane HBox.hgrow="ALWAYS">

            <!-- Top: Header -->
            <top>
                <HBox styleClass="header-main" alignment="CENTER_LEFT">
                    <Label text="EconoNova FX" styleClass="header-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="currentUserLabel" text="Usuario: Admin" styleClass="header-user"/>
                    <Button text="Cerrar Sesión" onAction="#handleLogout" styleClass="header-logout"/>
                </HBox>
            </top>

            <!-- Center: Content Area with Scroll -->
            <center>
                <ScrollPane fx:id="contentScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="content-scroll">
                    <StackPane fx:id="contentArea" styleClass="bg-gray-50, p-6"/>
                </ScrollPane>
            </center>
        </BorderPane>

    </HBox>

    <!-- Status Bar (Full Width, Below Sidebar) -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" VBox.vgrow="NEVER">
        <Label fx:id="statusLabel" text="Listo" styleClass="text-gray-500, text-xs, font-medium"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="EconoNova FX v1.0.0" styleClass="text-gray-500, text-xs, font-medium"/>
    </HBox>

</VBox>
