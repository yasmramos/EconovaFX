<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootView" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.econovafx.ui.controller.ExchangeRatesController"
      spacing="10" styleClass="content-view">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Gestión de Tasas de Cambio" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Button text="🔄 Actualizar" onAction="#handleRefreshRates" styleClass="btn-primary"/>
    </HBox>

    <!-- Active Rates Section -->
    <TitledPane text="Tasas Activas (Vigentes)" expanded="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10">
            <HBox alignment="CENTER_RIGHT" spacing="5">
                <Label fx:id="lastUpdateLabel" styleClass="info-label"/>
            </HBox>
            <TableView fx:id="activeRatesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="currencyCodeCol" text="Código" prefWidth="80"/>
                    <TableColumn fx:id="currencyNameCol" text="Moneda" prefWidth="150"/>
                    <TableColumn fx:id="buyRateCol" text="Compra" prefWidth="100"/>
                    <TableColumn fx:id="sellRateCol" text="Venta" prefWidth="100"/>
                    <TableColumn fx:id="dateCol" text="Fecha" prefWidth="120"/>
                    <TableColumn fx:id="sourceCol" text="Fuente" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>

    <!-- Historical Rates Section -->
    <TitledPane text="Histórico de Tasas" expanded="true" VBox.vgrow="ALWAYS">
        <VBox spacing="10">
            <!-- Filters -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Desde:"/>
                <DatePicker fx:id="fromDatePicker" prefWidth="150"/>
                <Label text="Hasta:"/>
                <DatePicker fx:id="toDatePicker" prefWidth="150"/>
                <Label text="Moneda:"/>
                <ComboBox fx:id="currencyFilterCombo" prefWidth="120"/>
                <Button text="🔍 Buscar" onAction="#handleSearchHistory" styleClass="btn-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📄 Exportar CSV" onAction="#handleExportToCSV" styleClass="btn-success"/>
            </HBox>
            
            <!-- Historical Table -->
            <TableView fx:id="historicalRatesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="histCurrencyCodeCol" text="Código" prefWidth="80"/>
                    <TableColumn fx:id="histDateCol" text="Fecha" prefWidth="120"/>
                    <TableColumn fx:id="histBuyRateCol" text="Compra" prefWidth="100"/>
                    <TableColumn fx:id="histSellRateCol" text="Venta" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>

</VBox>
