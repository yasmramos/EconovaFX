<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<!-- Main Dialog Container with Web Style -->
<VBox styleClass="dialog-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.econovafx.ui.controller.ComprobanteFormController">

    <!-- Dialog Header -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="dialog-header">
        <VBox>
            <Label fx:id="titleLabel" styleClass="dialog-title" text="Nuevo Comprobante" />
            <Label styleClass="dialog-subtitle" text="Cree un nuevo comprobante contable con asientos de partida doble" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#cancel" styleClass="dialog-close-btn" text="✕" />
    </HBox>

    <!-- Dialog Body -->
    <VBox spacing="16" styleClass="dialog-body">

        <!-- Form Fields Section -->
        <VBox styleClass="form-section" spacing="12">
            <GridPane hgap="16" vgap="12">
                <columnConstraints>
                    <ColumnConstraints percentWidth="20" />
                    <ColumnConstraints percentWidth="30" />
                    <ColumnConstraints percentWidth="20" />
                    <ColumnConstraints percentWidth="30" />
                </columnConstraints>

                <Label styleClass="form-label" text="Número:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <Label fx:id="numberLabel" styleClass="stat-value" text="(Automático)" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label styleClass="form-label" text="Fecha:*" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                <DatePicker fx:id="datePicker" promptText="Seleccione fecha" styleClass="form-date-picker" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                <Label styleClass="form-label" text="Descripción:*" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="4" />
                <TextField fx:id="descriptionField" promptText="Descripción del comprobante" styleClass="form-input" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="4" />
                <rowConstraints>
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                    <RowConstraints />
                </rowConstraints>
            </GridPane>
        </VBox>

    <!-- Entries Section -->
        <VBox styleClass="form-section" spacing="12" VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label styleClass="form-section-title" text="📝 Asientos Contables" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#addEntry" styleClass="btn-success" text="➕ Agregar Línea" />
                <Button onAction="#removeEntry" styleClass="btn-ghost" text="🗑️ Eliminar" />
            </HBox>

        <!-- Entries Table -->
        <TableView fx:id="entriesTable" styleClass="dialog-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colCta" prefWidth="60" text="CTA" />
                <TableColumn fx:id="colSbcta" prefWidth="60" text="SBCTA" />
                <TableColumn fx:id="colSctro" prefWidth="60" text="SCTRO" />
                <TableColumn fx:id="colAnal" prefWidth="60" text="ANAL" />
                <TableColumn fx:id="colEpig" prefWidth="60" text="EPIG" />
                <TableColumn fx:id="colDebit" prefWidth="120" text="Débito" />
                <TableColumn fx:id="colCredit" prefWidth="120" text="Crédito" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <!-- Account Selection -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="bg-gray-50, p-3, rounded-lg">
            <Label styleClass="form-label" text="💡 Instrucciones:" />
            <Label styleClass="info-label" text="Seleccione una fila y use los ComboBox en cada columna para elegir cuentas jerárquicamente" />
        </HBox>

        <!-- Totals -->
        <HBox alignment="CENTER_RIGHT" spacing="24" styleClass="bg-gray-50, p-3, rounded-lg">
            <VBox alignment="CENTER_RIGHT">
                <Label styleClass="form-label" text="Total Debe:" />
                <Label fx:id="totalDebitLabel" styleClass="stat-value, value-positive" text="0.00" />
            </VBox>
            <VBox alignment="CENTER_RIGHT">
                <Label styleClass="form-label" text="Total Haber:" />
                <Label fx:id="totalCreditLabel" styleClass="stat-value, value-info" text="0.00" />
            </VBox>
            <Separator orientation="VERTICAL" styleClass="dialog-separator" />
            <VBox alignment="CENTER_RIGHT">
                <Label styleClass="form-label" text="Diferencia:" />
                <Label fx:id="differenceLabel" styleClass="stat-value, value-warning" text="0.00" />
            </VBox>
        </HBox>

        <!-- Validation Message -->
        <Label fx:id="validationLabel" styleClass="error-label" text="⚠️ El comprobante debe estar balanceado (Debe = Haber)" visible="false" managed="false" />

        <!-- Action Buttons Footer -->
        <HBox alignment="CENTER_RIGHT" spacing="12" styleClass="bg-white">
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#cancel" styleClass="btn-ghost" text="❌ Cancelar" />
            <Button onAction="#save" styleClass="btn-primary" text="💾 Guardar Comprobante" />
        </HBox>
    </VBox>
    </VBox>
</VBox>
